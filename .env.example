# PostgreSQL connection — used by the backend and ML pipeline.
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_ME@localhost:5432/vedanta_risk

ENVIRONMENT=development
DEBUG=false

# Cron expression (5 fields, UTC) for the nightly ML pipeline retrain.
# Default: every day at 02:00 UTC.
RETRAIN_CRON=0 2 * * *

# ─────────────────────────────────────────────────────────────────────────────
# Optional — only needed if you use the standalone SQL Server CSV exporter
# at the repo root (`main.py`).  This connects to the corporate SQL Server
# OL_INCIDENTS table to produce CSVs in `exports/`.  Not used by the live API.
# ─────────────────────────────────────────────────────────────────────────────
# DB_HOST=your-sql-server-host
# DB_PORT=1433
# DB=vedanta
# DB_USER=your-user
# DB_PASSWD=your-password
# DATE_COLUMN=OCCUREDDATE

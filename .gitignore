# =============================================================================
# Risk Management Dashboard — .gitignore
# =============================================================================

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
ENV/
.env.local
pip-selfcheck.json

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
*.whl
*.tar.gz
site-packages/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover
coverage.xml
nosetests.xml

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ─── Node / Frontend ─────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/out/
.npm
.yarn/
.pnp.*
*.tsbuildinfo

# ─── Environment & Secrets ───────────────────────────────────────────────────
# .env.example is committed — .env is NOT (contains real credentials)
.env
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ─── Generated / Build output ────────────────────────────────────────────────
data/processed/*.parquet
data/processed/*.csv

# Alembic: only source migrations are committed, not __pycache__
backend/alembic/versions/__pycache__/

# ─── IDE & Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
pip-log.txt

# ─── AI assistant tooling ────────────────────────────────────────────────────
.claude/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
.cache/
